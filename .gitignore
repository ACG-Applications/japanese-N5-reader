# ============================================================
# .gitignore - Git Ignore File for JLPT N5 Reading App
# ============================================================

# ──────────────────────────────────────────────────────────────
# Operating System Files
# ──────────────────────────────────────────────────────────────

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
Thumbs.db

# Windows
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# Linux
*~

# ──────────────────────────────────────────────────────────────
# IDE and Editor Files
# ──────────────────────────────────────────────────────────────

# VSCode
.vscode/
*.code-workspace
.vscode-test/

# IntelliJ IDEA / WebStorm
.idea/
*.iml
out/
.idea_modules/

# Sublime Text
*.sublime-project
*.sublime-workspace
*.sublime-*

# Vim
*.swp
*.swo
*~

# ──────────────────────────────────────────────────────────────
# Package Managers (if used)
# ──────────────────────────────────────────────────────────────

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
.pnpm-debug.log*

# ──────────────────────────────────────────────────────────────
# Build Outputs (if using build tools)
# ──────────────────────────────────────────────────────────────

dist/
build/
out/
*.min.js
*.min.css

# ──────────────────────────────────────────────────────────────
# Testing
# ──────────────────────────────────────────────────────────────

coverage/
.nyc_output/
test-results/

# ──────────────────────────────────────────────────────────────
# Environment Variables
# ──────────────────────────────────────────────────────────────

.env
.env.local
.env.*.local

# ──────────────────────────────────────────────────────────────
# Development Files
# ──────────────────────────────────────────────────────────────

*.log
*.tmp
*.temp
*.cache

# ──────────────────────────────────────────────────────────────
# Security
# ──────────────────────────────────────────────────────────────

*.pem
*.key
*.crt
*.p12

# ──────────────────────────────────────────────────────────────
# User Data (keep local progress but don't commit)
# ──────────────────────────────────────────────────────────────

# Don't commit user progress data
*.db
*.sqlite
*.sqlite3
localStorage/

# ──────────────────────────────────────────────────────────────
# Documentation Generation
# ──────────────────────────────────────────────────────────────

docs/_build/
docs/api/

# ──────────────────────────────────────────────────────────────
# Backup Files
# ──────────────────────────────────────────────────────────────

*.bak
*.backup
*.old
*.orig

# ──────────────────────────────────────────────────────────────
# Archive Files
# ──────────────────────────────────────────────────────────────

*.zip
*.tar.gz
*.rar
*.7z

# ──────────────────────────────────────────────────────────────
# Screenshots (unless specifically added)
# ──────────────────────────────────────────────────────────────

screenshot-*.png
screenshot-*.jpg